{
  "name": "web",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "24.12.0",
    "pnpm": ">=10.17.1 <11"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "lint:legacy": "next lint",
    "analyze": "ANALYZE=true next build",
    "test": "vitest run",
    "e2e": "vitest -c vitest.config.e2e.mts run",
    "e2e:watch": "vitest -c vitest.config.e2e.mts",
    "e2e:dev": "WEB_BASE_URL=http://localhost:3000 vitest -c vitest.config.e2e.mts run"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.2",
    "next": "15.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "web-vitals": "4.2.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.6",
    "@next/bundle-analyzer": "15.5.20",
    "@next/eslint-plugin-next": "15.5.20",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "autoprefixer": "10.5.2",
    "axe-core": "4.12.1",
    "baseline-browser-mapping": "2.10.42",
    "eslint": "9.39.5",
    "eslint-config-next": "15.5.20",
    "eslint-import-resolver-typescript": "3.10.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "jsdom": "25.0.1",
    "postcss": "8.5.16",
    "puppeteer": "24.43.1",
    "schemas": "workspace:*",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
